@page "/"
@inject GameEngine Engine
@inject WeaponCatalog Weapons
@inject UpgradeCatalog Upgrades
@inject CanvasRenderer Renderer
@inject WebGpuEffectsRenderer Effects
@inject AudioService Audio
@inject BrowserStorage Storage
@implements IAsyncDisposable

<PageTitle>Armageddon Ridge</PageTitle>

<section class="game-root" @onkeydown="HandleKeyDown" tabindex="0">
    @if (_state is null)
    {
        <div class="menu-band">
            <div class="intro-copy">
                <div class="brand-block">
                    <span class="eyebrow">Blazor WebAssembly artillery showcase</span>
                    <h1><span>Armageddon</span><span>Ridge</span></h1>
                    <p>Wind. Terrain. Ridiculous ordnance. One more shot.</p>
                    <p class="best-score">Best score: @_bestScore</p>
                </div>
            </div>
            <div class="menu-actions">
                <div class="menu-actions-head">
                    <span class="eyebrow">Command deck</span>
                    <strong>Duel setup</strong>
                </div>
                <label>
                    Difficulty
                    <select @bind="_difficulty">
                        @foreach (var difficulty in DifficultyOptions)
                        {
                            <option value="@difficulty">@difficulty</option>
                        }
                    </select>
                </label>
                <button class="primary" @onclick="NewDuelAsync">New Duel</button>
                <button @onclick="ToggleSettings">Settings</button>
                <a class="ghost-link" href="benchmarks">Benchmarks</a>
            </div>
        </div>
    }
    else
    {
        <div class="battle-layout @BattleLayoutCss">
            <section class="@BattlefieldPanelCss">
                <canvas @ref="_canvas" class="battlefield" width="1200" height="700" aria-label="Armageddon Ridge battlefield"></canvas>
                <canvas @ref="_effectsCanvas" class="battlefield-effects" width="1200" height="700" aria-hidden="true"></canvas>
                @if (VisiblePhase == GamePhase.Battle)
                {
                    <button class="battlefield-fps-button" title="Toggle performance overlay" @onclick="TogglePerf">@FpsButtonText</button>
                }
                <div class="@BattleHudCss" aria-label="Battle health">
                    <div class="@PlayerVersusHealthCss">
                        <div class="fighter-label">
                            <span>Player</span>
                            <strong>@DisplayTankHealth(_state.PlayerTank, true) HP</strong>
                        </div>
                        <div class="fighter-bar health">
                            <span style="width:@TankHealthWidth(_state.PlayerTank, true)"></span>
                        </div>
                        <div class="fighter-bar shield">
                            <span style="width:@TankShieldWidth(_state.PlayerTank, true)"></span>
                        </div>
                    </div>

                    <div class="round-chip">
                        <span>Round @_state.RoundNumber</span>
                        <strong>@VisiblePhase</strong>
                        <small class="round-wind">Wind @WindText</small>
                    </div>

                    <div class="@CpuVersusHealthCss">
                        <div class="fighter-label">
                            <span>@_state.CpuTank.Name</span>
                            <strong>@DisplayTankHealth(_state.CpuTank, false) HP</strong>
                        </div>
                        <div class="fighter-bar health">
                            <span style="width:@TankHealthWidth(_state.CpuTank, false)"></span>
                        </div>
                        <div class="fighter-bar shield">
                            <span style="width:@TankShieldWidth(_state.CpuTank, false)"></span>
                        </div>
                    </div>
                </div>
                @if (_showPerf)
                {
                    <div class="perf-overlay">
                        <strong>Perf</strong>
                        <span>FPS: @_fps</span>
                        <span>Mode: @_rendererModeLabel</span>
                        <span>Frame: @_frameMs.ToString("0.00") ms</span>
                        <span>Render: @_renderMs.ToString("0.00") ms</span>
                        <span>Scene: @_sceneBuildMs.ToString("0.00") ms</span>
                        <span>Commands: @_commandBuildMs.ToString("0.00") ms</span>
                        <span>Submit: @_submitMs.ToString("0.00") ms</span>
                        <span>Batch: @_commandCount / @_payloadBytes bytes</span>
                        <span>SIMD: @SimdStatusLabel</span>
                        <span>FX: @EffectsStatusLabel</span>
                        <span>FX Quality: @_effectQualityTier</span>
                        <span>FX Frame: @_effectFrameMs.ToString("0.00") ms</span>
                        <span>FX Post: @_effectPostProcessMs.ToString("0.00") ms</span>
                        <span>FX Copy: @_effectSourceCopyMs.ToString("0.00") ms</span>
                        <span>FX Particles: @_effectActiveParticleCount / @_effectParticleCapacity (@_effectParticleCount)</span>
                        <span>FX Radials: @_effectRadialEffectCount</span>
                        <span>FX Scale: @_effectOverlayScale.ToString("0.00") @@ @_effectCanvasPixelRatio.ToString("0.0")x</span>
                        <span>FX Copy Cadence: @_effectSourceCopyCadence</span>
                        <span>FX GPU Queue: @_effectGpuQueueMs.ToString("0.00") ms</span>
                        <span>FX Perf: @_effectPerfMode</span>
                        <span>FX Spawns: @_effectSpawnCount</span>
                        <span>Sim: @_state.LastPerformance.SimulationMs.ToString("0.00") ms</span>
                        <span>Terrain: @_state.LastPerformance.TerrainMs.ToString("0.00") ms</span>
                        <span>CPU: @_state.LastPerformance.CpuPlanningMs.ToString("0.00") ms</span>
                        <span>Trail: @_state.LastPerformance.TrailPoints</span>
                    </div>
                }
                @if (VisiblePhase == GamePhase.Battle && !string.IsNullOrWhiteSpace(LatestCombatEvent))
                {
                    <div class="taunt" aria-live="polite">@LatestCombatEvent</div>
                }
                @if (VisiblePhase == GamePhase.Battle)
                {
                    <div class="battle-console" aria-label="Battle controls">
                        <label class="console-field console-weapon">
                            <span>Weapon <strong>@InventoryLabel(_state.SelectedWeaponId)</strong></span>
                            <select @bind="_state.SelectedWeaponId" aria-label="Weapon">
                                @foreach (var weapon in AvailablePlayerWeapons)
                                {
                                    <option value="@weapon.Id">@weapon.DisplayName (@InventoryLabel(weapon.Id))</option>
                                }
                            </select>
                        </label>
                        <label class="console-field">
                            <span>Angle <strong>@_state.PlayerTank.TurretAngle.ToString("0")</strong></span>
                            <input type="range" min="5" max="85" step="1" value="@AngleScrubValue" @oninput="HandleAngleScrubInputAsync" aria-label="Angle" />
                        </label>
                        <label class="console-field">
                            <span>Velocity <strong>@_power</strong></span>
                            <input type="range" min="1" max="100" step="1" @bind="_power" @bind:event="oninput" aria-label="Velocity" />
                        </label>
                        <button class="fire-button console-fire" disabled="@(!CanFirePlayer)" @onclick="FirePlayerAsync">Fire</button>
                    </div>
                }
            </section>

            <aside class="hud-panel">
                <header class="hud-header">
                    <div>
                        <span class="eyebrow">Round @_state.RoundNumber</span>
                        <h2>@VisiblePhase</h2>
                    </div>
                    <div class="hud-actions">
                        <button title="Toggle performance overlay" @onclick="TogglePerf">FPS</button>
                    </div>
                </header>

                <div class="tank-bars">
                    <TankReadout Label="Player"
                                 Tank="_state.PlayerTank"
                                 DisplayHealth="DisplayTankHealth(_state.PlayerTank, true)"
                                 DisplayShield="DisplayTankShield(_state.PlayerTank, true)"
                                 HealthHit="_playerHurt"
                                 ShieldHit="_playerShieldHit" />
                    <TankReadout Label="@_state.CpuTank.Name"
                                 Tank="_state.CpuTank"
                                 DisplayHealth="DisplayTankHealth(_state.CpuTank, false)"
                                 DisplayShield="DisplayTankShield(_state.CpuTank, false)"
                                 HealthHit="_cpuHurt"
                                 ShieldHit="_cpuShieldHit" />
                </div>

                <div class="wind-card">
                    <span>Wind</span>
                    <strong>@WindText</strong>
                </div>

                @if (VisiblePhase == GamePhase.Shop)
                {
                    <ShopPanel Weapons="AllWeapons"
                               Upgrades="AllUpgrades"
                               State="_state"
                               TargetingComputerEnabledByDefault="_targetingComputerEnabledByDefault"
                               OnBuyWeapon="BuyWeaponAsync"
                               OnBuyUpgrade="BuyUpgradeAsync"
                               OnStartBattle="StartBattleAsync" />
                }
                else if (VisiblePhase == GamePhase.RoundOver)
                {
                    <div class="modal-card">
                        <h3>@RoundResult</h3>
                        <p>Damage dealt: @_state.DamageDealtByPlayer.ToString("0")</p>
                        <p>Shots fired: @_state.ShotsFired</p>
                        <p>Cash: @_state.PlayerTank.Cash</p>
                        <button class="primary" @onclick="NextRoundAsync">Continue to shop</button>
                    </div>
                }
                else
                {
                    <div class="controls-card">
                        <label>
                            Weapon
                            <select @bind="_state.SelectedWeaponId">
                                @foreach (var weapon in AvailablePlayerWeapons)
                                {
                                    <option value="@weapon.Id">@weapon.DisplayName (@InventoryLabel(weapon.Id))</option>
                                }
                            </select>
                        </label>
                        <label>
                            Angle <strong>@_state.PlayerTank.TurretAngle.ToString("0")</strong>
                            <input type="range" min="5" max="85" step="1" value="@_state.PlayerTank.TurretAngle" @oninput="HandleAngleInputAsync" />
                        </label>
                        <label>
                            Velocity <strong>@_power</strong>
                            <input type="range" min="1" max="100" step="1" @bind="_power" @bind:event="oninput" />
                        </label>
                        <button class="fire-button" disabled="@(!CanFirePlayer)" @onclick="FirePlayerAsync">Fire</button>
                        <p class="hint">@HintText</p>
                    </div>
                }
            </aside>
        </div>
    }

    @if (_settingsOpen)
    {
        <div class="settings-drawer">
            <header class="settings-head">
                <div>
                    <span class="eyebrow">Game options</span>
                    <h2>Settings</h2>
                </div>
                <button class="icon-button" title="Close settings" @onclick="ToggleSettings">&times;</button>
            </header>
            <label class="settings-row">
                <span>Screen shake</span>
                <input type="checkbox" checked="@_screenShake" @onchange="HandleScreenShakeChangedAsync" />
            </label>
            <label class="settings-row">
                <span>Reduced motion</span>
                <input type="checkbox" checked="@_reducedMotion" @onchange="HandleReducedMotionChangedAsync" />
            </label>
            <label class="settings-row">
                <span>Targeting computer</span>
                <input type="checkbox" checked="@_targetingComputerEnabledByDefault" @onchange="HandleTargetingComputerChangedAsync" />
            </label>
            <label class="settings-row">
                <span>Rendering</span>
                <select value="@_renderMode" @onchange="HandleRenderModeChangedAsync">
                    @foreach (var mode in RenderModeOptions)
                    {
                        <option value="@mode">@RenderModeLabel(mode)</option>
                    }
                </select>
            </label>
            <label class="settings-row">
                <span>WebGPU effects</span>
                <span class="settings-inline">
                    <small>@EffectsStatusLabel</small>
                    <input type="checkbox" checked="@_webGpuEffectsEnabled" @onchange="HandleWebGpuEffectsChangedAsync" />
                </span>
            </label>
            <label class="settings-row range-row">
                <span>SFX volume</span>
                <input type="range" min="0" max="1" step="0.05" @bind="_sfxVolume" @bind:event="oninput" @onchange="ApplyAudioSettingsAsync" />
            </label>
            <label class="settings-row money-row">
                <span>Starting cash</span>
                <input type="number" min="500" max="10000" step="250" value="@_startingCash" @onchange="HandleStartingCashChangedAsync" />
            </label>
        </div>
    }
</section>
