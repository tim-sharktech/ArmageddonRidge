@using ArmageddonRidge.Core.Models

<div class="shop-panel">
    <div class="shop-head">
        <div>
            <span class="eyebrow">Cash</span>
            <strong>@State.PlayerTank.Cash</strong>
        </div>
        <button class="primary" @onclick="OnStartBattle">Start battle</button>
    </div>

    <div class="shop-list">
        <h3>Weapons</h3>
        @foreach (var weapon in _visibleWeapons)
        {
            <article class="shop-item">
                <img src="@IconFor(weapon.Id)" alt="" />
                <div>
                    <strong>@weapon.DisplayName</strong>
                    <span>@weapon.Cost cash</span>
                    <small>@weapon.Description</small>
                </div>
                <button disabled="@(State.PlayerTank.Cash < weapon.Cost)" @onclick="() => BuyWeaponAsync(weapon.Id)">Buy</button>
            </article>
        }

        <h3>Defense</h3>
        @foreach (var upgrade in _visibleUpgrades)
        {
            <article class="shop-item">
                <img src="@IconFor(upgrade.Type.ToString())" alt="" />
                <div>
                    <strong>@upgrade.DisplayName</strong>
                    <span>@upgrade.Cost cash</span>
                    @if (!string.IsNullOrEmpty(UpgradeCountLabel(upgrade.Type)))
                    {
                        <span class="owned-count">@UpgradeCountLabel(upgrade.Type)</span>
                    }
                    <small>@upgrade.Description</small>
                </div>
                <button disabled="@(State.PlayerTank.Cash < upgrade.Cost)" @onclick="() => BuyUpgradeAsync(upgrade.Type)">Buy</button>
            </article>
        }
    </div>
</div>
